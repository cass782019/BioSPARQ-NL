# Anthropic API key para avaliacao com Claude Sonnet (upper bound comercial)
ANTHROPIC_API_KEY=sk-ant-api03-...

# NER backend plugavel (opcoes: scispacy | gilda | llm | medcat)
NER_BACKEND=scispacy

# Endpoint Fuseki (usado pelo scispacy backend para resolucao de URIs)
FUSEKI_ENDPOINT=http://localhost:3030/biomedical/sparql

# LM Studio URL (usado pelo llm backend para extracao de spans)
LLM_BASE_URL=http://localhost:1234/v1
